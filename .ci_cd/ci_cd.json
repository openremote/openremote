{
	"push": {
		"master": {
			"distribute": {
				"docker": "develop-core",
				"maven": "$version-SNAPSHOT",
				"npm": "$version-snapshot"
			},
			"deploy": {
				"managerTag": "develop",
				"environment": "staging"
			}
		}
	},
	"release": {
		"distribute": {
			"docker": "$version-core,latest-core",
			"maven": "$version",
			"npm": "$version"
		},
		"deploy": {
			"managerTag": "latest",
			"environment": "demo"
		}
	}
}
